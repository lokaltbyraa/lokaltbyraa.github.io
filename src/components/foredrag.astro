---

import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

// sort by id (string)
// const foredrag: CollectionEntry<'foredrag'>[] =
//   (await getCollection('foredrag'))
//     .slice()
//     .sort((a, b) => a.id.localeCompare(b.id, "nb", { sensitivity: "base" }));

// importing foredrag data from JSON file instead of collection
import foredragData from '../content/foredrag/foredrag.json';

// Sort by id (string)
const foredrag = foredragData
    .slice()
    .sort((a, b) => b.år - a.år);
---

<div class="section" id="foredrag">
    <h2>Foredrag</h2>
    <p>Vi holder gjerne foredrag om våre prosjekter og metodikk tilpasset din kontekst og dine behov. Her er opplegg og foredrag vi har laget på bestilling for andre.</p>

    <div id="tableWrapperForedrag" class="closedTable">
        <table id="myTableForedrag">
        <thead>
            <tr>
                <th onclick="sortTable(0)">Oppdragsgiver</th>
                <th onclick="sortTable(0)">Setting</th>
                <th onclick="sortTable(1)">Bestilling</th>
                <th onclick="sortTable(2)">Tittel på foredrag</th>
                <th onclick="sortTable(3)">År</th>
            </tr>
        </thead>
        <tbody>

            {foredrag.map(foredrag => ( 
                <tr>
                    <td class="kunde bold">{foredrag.kunde}</td>
                    <td class="avdeling">{foredrag.avdeling}</td>
                    <td class="bestilling"><span class="forklaring">Bestilling: </span>{foredrag.bestilling}</td>
                    <td class="tittel"><span class="forklaring">Tittel: </span>{foredrag.tittel}</td>
                    <td class="år">{foredrag.år}</td>
                </tr>
                ))}
        </tbody>
        </table>
    </div>

    <div class="buttonDiv">
    <button id="expandBtnForedrag" onclick="toggleTableForedrag()">Vis alle foredrag</button>
    </div>

</div>

<style>

    div{
        transition: max-height 0.3s ease-in-out;
    }

    p{
        font-size: 1.5em;
        max-width: 70ch;
        text-wrap: balance;
    }

    table{
        width: 100%;
        border-collapse: separate;
        text-align: left;
        margin: 3em 0 0;
        --arrowColor: black;
        line-height: 1.25em;
        position: relative;
    }

       #tableWrapperForedragr{
        position: relative;
        height: auto;
    }

    .closedTable{
       max-height: 35em;
       overflow: hidden;
       position: relative;
    }

    .expandedTable {
        max-height: 5000px;  /* set a large enough value */
    }

    .buttonDiv{
        width: 100%;
        text-align: center;
        margin-top: .5em;
        z-index: 3;
    }

    button:hover{
        font-weight: bold;
    }
    #tableWrapperForedrag::after {
    z-index: 2;
    content: "";
    position: absolute;     
    bottom: 0;
    left: 0;
    width: 100%;
    height: 7em;        
    pointer-events: none; 
    background: linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0) 0%, 
        var(--light) 95%               
    );
    }

    #tableWrapperForedrag.closedTable::after {
    display: block;
    }

    /* when expanded, hide overlay */
    #tableWrapperForedrag.expandedTable::after {
        display: none;
    }

    .section{
        width: 100%;
    }

    th, td{
    }

    th{
        border-bottom: 2.5px solid black;
        font-size: 1.65em;
        padding: 0 0.5rem 0.45em;
    }

    td{
        border-bottom: 1px solid black;
        font-size: 1em;
        padding: 0.7em 0.5rem 0.5em;
        max-width: 40ch;
        /* font-size: 1.25em;
        line-height: 1.25em; */
    }
    
    tr:nth-child(even) td{
        background-color: white;
    }

    .link{
        opacity: 0;
        font-size: 1.25em;
        line-height: 0;
        padding-left: 0.5ch;
    }

    tr:hover .link{
        opacity: 1;
        fill: var(--blue);
        text-wrap: balance;
    }

    .kunde, .avdeling{
        max-width: 20ch;
    }

    .arrowRow{
        width: 1ch;
        opacity: 0;
    }

    .forklaring{
        display: none;
    }

    /* tr:hover{
        color: var(--red);
        --arrowColor: var(--blueDark);
        text-decoration: underline;
    } */


@media screen and (max-width: 650px) {
    
    #tableWrapper{
        height: auto;
    }

    p{
        text-wrap: initial;
    }

    th{
        display: none;
    }

    table{
        margin-top: 0;
    }

    table tr {
      display: grid;
        grid-template-columns: auto min-content;
        gap: 0 2em;
      width: 100%;
      margin: 0;
      padding: 1em 0 1.25em;
      border-bottom: 1px solid black;
    }
    
    table td {
      display: block;
      margin-bottom: 0.25em;
      width: 100%;
      border: none;
      padding: 0;
      background: none !important;
      max-width: none;
    }

    table *{
        text-wrap: balance;
    }
    .kunde{
        grid-row: 1;
        grid-column: 1;
        font-size: 1.15em;
    }

    .år{
        grid-row: 1;
        grid-column: 2;
        text-align: right;
        justify-self: end;
        /* font-size: 1.15em; */
    }

    .avdeling{
        grid-row: 2;
        grid-column: 1 / span 2;
        font-style: italic;
    }

    .bestilling{
        grid-row: 3;
        grid-column: 1 / span 2;
        margin-top: 0.5em;
        width: 100%;
    }

    .tittel{
        grid-row: 4;
        grid-column: 1 / span 2;
        margin-top: 0.5em;
        width: 100%;
    }

    .forklaring{
    font-weight: bold;
    display: inline;
    }


    /* table td:nth-child(odd){
        width: 100%;
        padding-right: 0;
        padding-top: 0.5em;
        padding-bottom: 0.1em;
    }

    table td:nth-child(even){
        padding-bottom: 0.55em;
    } */
    
  }

</style>

<script>
    declare global {
    interface Window {
      toggleTableForedrag: () => void;
    }
    }

  function toggleTableForedrag() {
    const w = document.getElementById('tableWrapperForedrag');
    const b = document.getElementById('expandBtnForedrag');
    if (!w || !b) return;

    const closed = w.classList.contains('closedTable');
    w.classList.toggle('closedTable', !closed);
    w.classList.toggle('expandedTable', closed);
    b.textContent = closed ? 'Skjul foredrag' : 'Vis alle foredrag';
  }

  window.toggleTableForedrag = toggleTableForedrag;
</script>