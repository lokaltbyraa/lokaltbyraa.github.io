@media screen and (max-width: 650px) {
    
    #tableWrapper{
        height: auto;
    }

    th{
        display: none;
    }

    table tr {
      display: grid;
        grid-template-columns: 1fr 1fr;
      width: 100%;
      margin: 0;
      padding: 0.35em 0 1em;
      border-bottom: 1px solid black;
    }
    
    table td {
      display: block;
      margin-bottom: 0.15em;
      width: 100%;
      border: none;
      padding: 0;
      background: none !important;
      max-width: none;
    }

    .oppdragsgiver{
        grid-row: 1;
        grid-column: 1;
        font-size: 1.15em;
    }

    .årstall{
        grid-row: 1;
        grid-column: 2;
        text-align: right;
        justify-self: end;
        /* font-size: 1.15em; */
    }

    .prosjektnavn{
        grid-row: 2;
        grid-column: 1 / span 2;
        font-style: italic;
    }

    .tema{
        grid-row: 3;
        grid-column: 1 / span 2;
        margin-top: 0.5em;
        width: 100%;
    }

    .samarbeidspartner{
        grid-row: 4;
        grid-column: 1 / span 2;
        margin-top: 0.5em;
        display: none !important;
    }

