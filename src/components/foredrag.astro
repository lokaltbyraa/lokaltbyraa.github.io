---

import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

// sort by id (string)
const foredrag: CollectionEntry<'foredrag'>[] =
  (await getCollection('foredrag'))
    .slice()
    .sort((a, b) => a.id.localeCompare(b.id, "nb", { sensitivity: "base" }));
---

<div class="section" id="foredrag">
    <h2>Foredrag</h2>
    <p>Vi holder gjerne foredrag om våre prosjekter og metodikk tilpasset din kontekst og dine behov. Her er opplegg og foredrag vi har laget på bestilling for andre.</p>

    <div id="tableWrapper" class="closedTable">
        <table id="myTable">
        <thead>
            <tr>
                <th onclick="sortTable(0)">Tittel</th>
                <th onclick="sortTable(1)">Utviklet for</th>
            </tr>
        </thead>
        <tbody>

            {foredrag.map(foredrag => ( 
                <tr>
                    <td class="tittel">{foredrag.data.tittel}</td>
                    <td class="kunde">{foredrag.data.kunde}</td>
                </tr>
                ))}
        </tbody>
        </table>
    </div>

</div>

<style>

    p{
        font-size: 1.5em;
        max-width: 70ch;
        text-wrap: balance;
    }

    table{
        width: 100%;
        border-collapse: separate;
        text-align: left;
        margin: 3em 0;
        --arrowColor: black;
        line-height: 1.25em;
    }

    #tableWrapper{
        position: relative;
    }

    .closedTable{
       
    }

    .buttonDiv{
        width: 100%;
        text-align: center;
    }

    button:hover{
        font-weight: bold;
    }

