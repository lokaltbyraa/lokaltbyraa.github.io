---
import LbLogo from '../components/lbLogo.astro';
import '../styles/headerLogoPlacement.css';

export interface Props {
  color?: string;
  currentPath?: string;
}

const { color = "black", currentPath = "/" } = Astro.props as Props;

const isHome = currentPath === '/' || currentPath === '/index.html';
const isOmOss = currentPath === '/om-oss' || currentPath === '/om-oss/';
const isStudenter = currentPath === '/studenter' || currentPath === '/studenter/';
---

<header>
  <div class="wrapper">
    <div class="section gridHeader">
      <!-- Hamburger button only visible on mobile -->
      <button id="hamburger" class="hamburger" aria-label="Toggle navigation menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <!-- Desktop Links -->
      <nav class="links">
        <a href="/" class={`text show ${isHome ? 'active' : ''}`}><span>Hjem</span></a>
        <a href="/om-oss" class={`text show ${isOmOss ? 'active' : ''}`}><span>Om oss</span></a>
        <a href="/studenter" class={`text show ${isStudenter ? 'active' : ''}`}><span>For studenter</span></a>
        <a href="#kontakt" class="text show"><span>Kontakt</span></a>
      </nav>

      <!-- Full-screen overlay for mobile menu -->
      <div id="mobile-overlay" class="mobile-overlay">
        <div class="overlay-content">
          <a href="/" class={`overlay-link ${isHome ? 'active' : ''}`}>Hjem</a>
          <a href="/om-oss" class={`overlay-link ${isOmOss ? 'active' : ''}`}>Om oss</a>
          <a href="/studenter" class={`overlay-link ${isStudenter ? 'active' : ''}`}>For studenter</a>
          <a href="#kontakt" class="overlay-link">Kontakt</a>
        </div>
      </div>

      <a href="/" aria-label="Hjem" class="logoLink">
        <LbLogo rotation={true}/>
      </a>
    </div>
  </div>
</header>

<script>

  // Hamburger toggle
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement | null;
  const overlay = document.getElementById('mobile-overlay') as HTMLDivElement | null;
  let isOpen = false;

  if (hamburger) {
    hamburger.addEventListener('click', () => {
      isOpen = !isOpen;
      if (overlay) {
        overlay.classList.toggle('open', isOpen);
      }
      hamburger.classList.toggle('open', isOpen);
    });
  }

  if (overlay) {
    overlay.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (target && target.tagName === 'A') {
        isOpen = false;
        overlay.classList.remove('open');
        if (hamburger) {
          hamburger.classList.remove('open');
        }
      }
    });
  }
</script>

<style define:vars={{ textColor: color }}>
  .gridHeader {
    display: grid;
    grid-template-columns: 1fr 1fr;
    justify-content: space-between;
    margin-bottom: 0;
  }

  .links {
    display: flex;
    gap: 2em;
    align-items: start;
    margin-top: 1em;
  }

  a {
    text-decoration: none;
  }

  .logoLink {
    justify-self: end;
  }

  .text span {
    color: var(--textColor);
    --arrowColor: var(--textColor);
    text-decoration: none;
    margin-bottom: 0.5em;
    border-bottom: 1px solid var(--textColor);
    padding-bottom: 0.1em;
    display: none;
    margin: 2rem 0;
    font-size: 1.35rem;
    text-shadow: 0px var(--shadowOffset) 0.3em rgba(0, 0, 0, 0.4);
  }

  .show span {
    display: flex !important;
    flex-direction: row;
    gap: 0.25ch;
    align-items: center;
  }

  .text span:hover {
    color: var(--red);
    --arrowColor: var(--red);
    border-color: var(--red);
  }

  .active span {
    font-weight: bold;
    border-bottom: 2.5px solid var(--textColor);
    margin-right: -.2ch;
  }

  .active span:hover {
    color: black;
    --arrowColor: black;
    border-color: black;
    cursor: default;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-around;
    width: 30px;
    height: 30px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
    transition: position scale 0.3s;
  }

  .hamburger.open {
    position: fixed;
    top: 0em;
    left: 2em;
  }

  .hamburger span {
    width: 100%;
    height: 3px;
    background: var(--textColor);
    transition: all 0.3s;
  }

  .hamburger.open span {
    background: white;
  }

  .hamburger.open span:nth-child(1) {
    transform: rotate(45deg) translate(3px, 11px) scale(1.5);
  }

  .hamburger.open span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.open span:nth-child(3) {
    transform: rotate(-45deg) translate(3px, -11px) scale(1.5);
  }

  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--red);
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 1000;
    transition: background 0.3s;
  }

  .mobile-overlay.open {
    display: flex;
  }

  .overlay-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    text-align: center;
  }

  .overlay-link {
    color: white;
    font-size: 2rem;
    text-decoration: none;
    padding: 1rem 0rem 0.5rem;
    margin-bottom: 0.5rem;
    transition: background 0.3s;
  }

  .overlay-link:hover {
    background: white;
    color: black;
  }

  .overlay-link.active {
    font-weight: bold;
    border-bottom: 2px solid white;
  }

  @media (width <= 1050px) {
    .text span {
      margin: 1rem 0.5rem;
      text-shadow: none;
      background-color: white;
      color: black;
      --arrowColor: black;
      padding: 0.5rem 1rem;
      border-radius: 3rem;
      font-size: 1.1rem;
      border: none;
    }

    .text span:hover {
      background-color: var(--red);
      color: black;
      --arrowColor: black;
    }

    .links {
      display: none;
    }

    .hamburger {
      display: flex;
      justify-self: start;
      margin-top: 3em;
    }

    header {
      grid-template-columns: auto 1fr auto;
      align-items: center;
    }

    .logoLink {
      justify-self: end;
    }
  }

  @media (width <= 810px) {
    header {
      margin-left: 1em;
    }
  }
</style>