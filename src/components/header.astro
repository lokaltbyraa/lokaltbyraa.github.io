---
import Arrow from '../components/arrow.astro';
import LbLogo from '../components/lbLogo.astro';

import '../styles/headerLogoPlacement.css';

export interface Props {
  color?: string;
}

const { color = "black" } = Astro.props as Props;

// const hidden = "hidden";

// Determine active link based on current path
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath.startsWith('/#');
const isOmOss = currentPath === '/om-oss';
const isStudenter = currentPath === '/studenter';

---

<header>
  <div class="wrapper">
    <div class="section gridHeader">
        <!-- Hamburger button only visible on mobile -->
        <button id="hamburger" class="hamburger" aria-label="Toggle navigation menu">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <!-- Desktop Links -->
        <nav class="links">
          <a href="/" class={`text show ${isHome ? 'active' : ''}`}><span class="">Hjem</span></a>
          <a href="/om-oss" class={`text show ${isOmOss ? 'active' : ''}`}><span class="">Om oss</span></a>
          <a href="/studenter" class={`text show ${isStudenter ? 'active' : ''}`}><span class="">For studenter</span></a>
        </nav>

        <!-- Full-screen overlay for mobile menu -->
        <div id="mobile-overlay" class="mobile-overlay">
          <div class="overlay-content">
            <a href="/" class={`overlay-link ${isHome ? 'active' : ''}`}>Hjem</a>
            <a href="/om-oss" class={`overlay-link ${isOmOss ? 'active' : ''}`}>Om oss</a>
            <a href="/studenter" class={`overlay-link ${isStudenter ? 'active' : ''}`}>For studenter</a>
          </div>
        </div>
  
        <a href="/" aria-label="Hjem" class="logoLink">
            <LbLogo rotation={true}/>
        </a>
    </div>
  </div>

</header>

<script>
  // Client-side script for hamburger toggle
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement | null;
  const overlay = document.getElementById('mobile-overlay') as HTMLDivElement | null;
  let isOpen = false;

  if (hamburger) {
    hamburger.addEventListener('click', () => {
      isOpen = !isOpen;
      if (overlay) {
        overlay.classList.toggle('open', isOpen);
      }
      hamburger.classList.toggle('open', isOpen);
    });
  }

  if (overlay) {
    // Close overlay on link click
    overlay.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (target && target.tagName === 'A') {
        isOpen = false;
        overlay.classList.remove('open');
        if (hamburger) {
          hamburger.classList.remove('open');
        }
      }
    });
  }
</script>

<style define:vars={{ textColor: color }}>
    .gridHeader{
    /* width: 100%; */
    /* max-width: 1600px;
    margin: 0 auto;
    padding-left: var(--edgeWhiteSpace); */
    /* margin-right:  var(--edgeWhiteSpace); */
    display: grid;
    grid-template-columns: 1fr 1fr;
    justify-content: space-between;
    margin-bottom: 0;
}

.links{
    display: flex;
    gap: 2em;
    align-items: start;
    margin-top: 1em;
}

a{
  text-decoration: none;
}

.logoLink{
  justify-self: end;
  /* margin-right:  var(--edgeWhiteSpace); */
}
.text span{
  color: var(--textColor);
  --arrowColor: var(--textColor);
  text-decoration: none;
  margin-bottom: 0.5em;
  border-bottom: 1px solid var(--textColor);
  padding-bottom: 0.1em;
  display: none;
  margin: 2rem 0;
  font-size: 1.35rem;
  text-shadow: 0px var(--shadowOffset) 0.3em rgba(0, 0, 0, 0.4);
}

.show span{
  display: flex !important;
  flex-direction: row;
  gap: 0.25ch;
  align-items: center;
}

.text span:hover{
  color: var(--red);
  --arrowColor: var(--red);
  border-color: var(--red);
}

.active span{
  font-weight: bold;
  border-bottom: 2.5px solid var(--textColor);
  margin-right: -.2ch;
}

.active span:hover{
  color: black;
  --arrowColor: black;
  border-color: black;
  cursor: default;
}

/* CSS from co-pilot */
.hamburger {
  display: none;
  flex-direction: column;
  justify-content: space-around;
  width: 30px;
  height: 30px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  z-index: 1001;
  transition: position scale 0.3s;
}
.hamburger.open {
  position: fixed;
  top: 4.35em;
  left: 2.5em;
  /* transform: scale(1.5); */
}
.hamburger span {
  width: 100%;
  height: 3px;
  background: var(--textColor);
  transition: all 0.3s;
}

.hamburger.open span {
  background: white;
}

.hamburger.open span:nth-child(1) {
  transform: rotate(45deg) translate(7px, 7px) scale(1.75);
}

.hamburger.open span:nth-child(2) {
  opacity: 0;
}

.hamburger.open span:nth-child(3) {
  transform: rotate(-45deg) translate(7px, -7px) scale(1.75);
}

/* Mobile overlay styles */
.mobile-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  /* background: rgba(0, 0, 0, 0.8); */
  background: var(--red);
  display: none;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  transition: background 0.3s;
}

.mobile-overlay.open {
  display: flex;
}

.overlay-content {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  text-align: center;
}

.overlay-link {
  color: white;
  font-size: 2rem;
  text-decoration: none;
  padding: 1rem;
  transition: background 0.3s;
}

.overlay-link:hover {
  background: white;
  color: black;
}

.overlay-link.active {
  font-weight: bold;
  border-bottom: 2px solid white;
}

@media (width <= 1050px ) {
  .text span{
  margin: 1rem 0.5rem;
  text-shadow: none;
  background-color: white;
  color: black;
  --arrowColor: black;
  padding: 0.5rem 1rem;
  border-radius: 3rem;
  font-size: 1.1rem;
  border: none;
  }

  .text span:hover{
    background-color: var(--red);
    color: black;
    --arrowColor: black;
  }

  /* Hide desktop links on mobile */
  .links {
    display: none;
  }

  /* Show hamburger on mobile */
  .hamburger {
    display: flex;
    justify-self: start;
    margin-top: 1em;
  }

  /* Adjust header grid for mobile */
  header {
    grid-template-columns: auto 1fr auto;
    align-items: center;
  }

  .logoLink {
    justify-self: end;
  }

}     

@media (width <= 810px ) {

    header{
        margin-left: 3em
    }

}

</style>