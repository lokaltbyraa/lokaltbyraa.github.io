---
//import { Image } from 'astro:assets';
//import LokaltByraaLogo from '../images/LokaltByraaLogo.png';
import Arrow from '../components/arrow.astro';
import LbLogo from '../components/lbLogo.astro';

import '../styles/headerLogoPlacement.css';

export interface Props {
  homeButton?: boolean;
}

const { homeButton = false } = Astro.props as Props;

// const hidden = "hidden";

// Determine active link based on current path
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath.startsWith('/#');
const isOmOss = currentPath === '/om-oss';
const isStudenter = currentPath === '/studenter';

---

<header>
  <div class="links">
    <!-- <a href="/#prosjekter" class={`text ${homeButton && 'show'}`}><span class="">
      <Arrow direction='left'/>
      Hjem</span></a> -->

    <a href="/" class={`text show ${isHome ? 'active' : ''}`}><span class="">
      <!-- <Arrow direction='left'/> -->
      Hjem</span></a>
    <a href="/om-oss" class={`text show ${isOmOss ? 'active' : ''}`}><span class="">Om oss</span></a>
    <a href="/studenter" class={`text show ${isStudenter ? 'active' : ''}`}><span class="">For studenter</span></a>
  </div>
  
    <a href="/" aria-label="Hjem">
        <LbLogo rotation={true}/>
        <!-- <Image src={LokaltByraaLogo} alt="Lokalt Byrå sin logo" id="logo" width={300}/> -->
    </a>

</header>

<style>
    header{
    max-width: 1600px;
    margin-left:  var(--edgeWhiteSpace);
    /* margin-right:  var(--edgeWhiteSpace); */
    display: flex;
    justify-content: space-between;
}

.links{
    display: flex;
    gap: 2em;
    align-items: start;
    margin-top: 1em;
}
a{
  text-decoration: none;
}

.text span{
  color: black;
  --arrowColor: black;
  text-decoration: none;
  margin-bottom: 0.5em;
  border-bottom: 1px solid black;
  padding-bottom: 0.1em;
  display: none;
  margin: 2rem 0;
  font-size: 1.35rem;
  text-shadow: 0px var(--shadowOffset) 0.3em rgba(0, 0, 0, 0.4);
}

.show span{
  display: flex !important;
  flex-direction: row;
  gap: 0.25ch;
  align-items: center;
}

.text span:hover{
  color: var(--red);
  --arrowColor: var(--red);
  border-color: var(--red);
}

.active span{
  font-weight: bold;
  border-bottom: 2.5px solid black;
}

.active span:hover{
  color: black;
  --arrowColor: black;
  border-color: black;
}

/* .logo{
    width: 10em;
    height: auto;
    margin: 2em 2em;
} */

@media (width <= 1050px ) {
  .text span{
  margin: 1rem 0.5rem;
  text-shadow: none;
  background-color: white;
  color: black;
  --arrowColor: black;
  padding: 0.5rem 1rem;
  border-radius: 3rem;
  font-size: 1.1rem;
  border: none;
  }

  .text span:hover{
    background-color: var(--red);
    color: black;
    --arrowColor: black;
  }

}   

</style>