    <li><span id="aktivitetshus">Aktivitetshus- og anlegg</span></li>
    <li><span id="kulturhus">Kulturhus og bibliotek</span></li>
    <li><span id="motesteder">Møtesteder</span></li>
    <li><span id="frivillighet">Frivillighet og samskaping</span></li>
    <li><span id="integrering">Integrering</span></li>
