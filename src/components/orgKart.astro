<h2>Vi har erfaring på tvers av sektorer og ser <span>sammenhengene</span>. Her er tema og virksomhetsområder vi har jobbet med.</h2>

<div class="section chart">

    <div class="top">
        <h3>Et miljømessig, sosialt og økonomisk bærekraftig samfunn</h3>
    </div>

    <div class="lineVertical"></div>
    <div class="lineVertical"></div>

   <div class="branch utvikling">
  <div class="sektor"><h4>Utvikling og samfunn</h4></div>
  <ul>
    <li><span id="folkehelse">Folkehelse</span></li>
    <li><span id="strategi">Strategi og tverrsektoriell ledelse</span></li>
    <li><span id="plan">Plan og byggesak</span></li>
    <li><span id="naering">Næringsutvikling</span></li>
    <li><span id="digitalisering">Digitalisering</span></li>
    <li><span id="stedsutvikling">Stedsutvikling og bolyst</span></li>
    <li><span id="klimatilpasning">Klimatilpasning</span></li>
  </ul>
</div>

<div class="branch helse">
  <div class="sektor"><h4>Helse og velferd</h4></div>
  <ul>
    <li><span id="boligsosialt">Boligsosialt arbeid</span></li>
    <li><span id="helsebygg">Helsebygg</span></li>
    <li><span id="tjenesteinnovasjon">Tjenesteinnovasjon</span></li>
