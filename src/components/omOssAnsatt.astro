---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

import '../styles/reset.css';
import '../styles/global.css';

interface Props {
    navn: string;
    stilling: string;
    bio: string;
    epost: string;
    tlf: number;
    imagePath: ImageMetadata;
    altText: string;
    utdanning: string[];
    tidligereErfaring: string[];
}

const {
    navn,
    stilling,
    epost,
    tlf,
    imagePath,
    altText,
    bio,
    utdanning = [],
    tidligereErfaring = []
    } = Astro.props;

// const images = import.meta.glob<{ default: ImageMetadata }>('/src/content/ansatte/*.{jpeg,jpg,png,gif}');
// if (!images["/src/content/ansatte/" + imagePath]) throw new Error(`"${imagePath}" does not exist in glob: "src/content/ansatte/*.{jpeg,jpg,png,gif}"`);
const images = import.meta.glob('/src/content/ansatte/*.{jpg,jpeg,png,gif}');
const imageModule = images[`/src/content/ansatte/${imagePath}`];
if (!imageModule) throw new Error(`Image not found: ${imagePath}`);

const resolvedImage = (await imageModule()).default;

---

<div class="grid">
    <div class="txtDiv">
        <h1>{navn}</h1>
        <h2>{stilling}</h2>
        <p>{bio}</p>
        <div class="txtGrid">
            <div>
                <h3>Utdanning</h3>
                <ul>
                    {utdanning.map((item) => (
                        <li>{item}</li>
                    ))}
                </ul>
            </div>

            <div>
                <h3>Tidligere erfaring</h3>
                <ul>
                    {tidligereErfaring.map((item) => (
                        <li>{item}</li>
                    ))}
                </ul>
            </div>
        </div>

        <p>
           Kontakt: <a href={"mailto:"+epost}>{epost}</a> <span class="divider">•</span> <a href={"tel:+47"+tlf}>{"+47 "+tlf}</a>
        </p>
    </div>

    <div class="imgDiv">
        <!-- <Image src={images["/src/content/ansatte/" + imagePath]()} alt={altText} width=600 quality={80}/> -->
        <Image src={resolvedImage} alt={"Bilde av "+altText} width={400} quality={80}/>
        
    </div>
</div>

<style>

    img{
    height: 100%;
    max-width: 30ch;
    /* aspect-ratio: 4 / 5; */
    object-fit: cover;
    border-radius: 0%;
    object-position: center bottom;
    }

    .grid{
        margin-top: 4em;
        display: grid;
        grid-template-columns: auto auto;
        grid-gap: 2em;
        /* max-width: 100ch; */
        justify-content: center;
        justify-items: baseline;
    }

    .txtDiv{
        max-width: 70ch;
    }

    .txtGrid{
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1em;
    }

    h1{
        font-size: 2.5em;
        margin: 0;
        line-height: 1.15;
    }

    h2{
        font-size: 1.5em;
        margin-top: 0.25em;
    }

    p{
        font-size: 1.1em;
    }


    li{
        margin: 0;
        padding: 0;
        margin-left: 1.5ch;
        padding-left: .5ch;
        list-style: disc;
        list-style-position: outside;
    }

    .imgDiv{
        grid-column: 1;
        grid-row: 1;
    }

    h3{
        margin-bottom: 0.35em;
    }

    .divider{
        margin: 0 .6ch 0 .7ch;
    }

    a:hover{
        color: var(--red);
    }

    @media screen and (max-width: 600px) {
    
    .grid{
        grid-template-columns: 1fr;
    }

    .txtDiv{
        grid-row: 2;
    }

    .imgDiv{
        grid-row: 1;
        justify-self: center;
    }

    img{
        width: 100%;
        max-width: 45ch;
        aspect-ratio: 1/1;
        object-position: center;
    }

    }

</style>